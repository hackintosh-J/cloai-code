{
  "name": "cloai-desktop",
  "private": true,
  "version": "0.0.3",
  "description": "cloai desktop frontend",
  "author": {
    "name": "cloai"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean:tauri:target": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path './src/native/target') { Remove-Item -Recurse -Force './src/native/target' }\"",
    "preview": "vite preview",
    "tauri:dev": "bun ./scripts/run-tauri.mjs dev",
    "tauri:build": "bun ./scripts/run-tauri.mjs build",
    "tauri:build:win": "bun ./scripts/run-tauri.mjs build --target x86_64-pc-windows-msvc",
    "tauri:build:win:clean": "bun run clean:tauri:target && bun ./scripts/run-tauri.mjs build --target x86_64-pc-windows-msvc",
    "tauri:build:mac": "bun ./scripts/run-tauri.mjs build --target universal-apple-darwin",
    "tauri:build:linux": "bun ./scripts/run-tauri.mjs build --target x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/spectral": "^5.2.8",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@remix-run/router": "1.15.3",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "gsap": "^3.15.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "9.0.1",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.7.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/katex": "^0.16.8",
    "@types/mermaid": "^9.1.0",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
