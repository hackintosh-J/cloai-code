{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cloai",
  "version": "0.0.2",
  "identifier": "com.cloai.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:17831",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cloai",
        "width": 1150,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg",
      "appimage"
    ],
    "resources": [
      "../../skills"
    ],
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "../../public/branding/app-icon.ico"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "icon": [
      "../../public/branding/app-icon.ico",
      "../../public/branding/app-icon.png"
    ]
  }
}
